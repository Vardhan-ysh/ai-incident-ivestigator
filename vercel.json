{
    "experimentalServices": {
        "frontend": {
            "entrypoint": "frontend",
            "framework": "vite",
            "routePrefix": "/"
        },
        "backend": {
            "entrypoint": "backend/index.py",
            "routePrefix": "/_/backend"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/_/backend/api/$1"
        }
    ]
}
